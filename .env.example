DB_HOST=localhost
DB_NAME=agora
DB_USER=agora
DB_PASS=agora
DB_PORT=5432

# Par défaut on bind en local uniquement.
# Sur Windows, si 127.0.0.1 est bloqué/réservé, mets: BIND_ADDR=0.0.0.0
BIND_ADDR=127.0.0.1

# Port **publié sur l’hôte** (mapping compose : ${BACKEND_PORT:-8081}:8080 — le 8080 à droite = port Spring *dans* le conteneur).
# Choisis un port libre sur ta machine ; aligne `proxy.conf.js` du front (ou AGORA_BACKEND_URL) sur la même valeur.
BACKEND_PORT=8082

ZABBIX_SERVER_IP=CHANGE_ME
ZABBIX_HOSTNAME=agora-app
ZABBIX_AGENT_PORT=10050

# dev pour démarrage local via Docker
SPRING_PROFILES_ACTIVE=dev